<script>
    document.getElementsByTagName("body")[0].classList.remove("noscript");

    let fontSiteCheckInterval = null;
    let fontArticleCheckInterval = null;
    let siteFont='12px "alarabiya"';
    let articleFont='12px "Noto Naskh Arabic Bold"';


    function fontLoadListener(fontName) {
        // console.log("fontLoadListener", fontName);
        var hasLoaded = false
        /*
         * If anything goes wrong with the font loading API,
         * just change styles to the web font without handling FOUT
         */
        try {
            hasLoaded = document.fonts.check(fontName)
        } catch (error) {
            console.log("document.fonts API error: {}", error);
            fontLoadedSuccess(fontName);
            return
        }
        if(hasLoaded) {
            fontLoadedSuccess(fontName);
        }
    }

    function fontLoadedSuccess(fontName) {
        try{

            //console.log("finished loading", fontName);
            if(fontName==siteFont){
                if(fontSiteCheckInterval) {
                    clearInterval(fontSiteCheckInterval);
                }
                document.getElementsByTagName("body")[0].classList.add("aa-font");
            }
            if(fontName==articleFont){
                if(fontArticleCheckInterval) {
                    clearInterval(fontArticleCheckInterval);
                }
                document.getElementsByTagName("article")[0].classList.add("aa-art-font");
            }
        }catch (e) {
            console.log("fontLoadedSuccess: {}", e);
        }
    }

    try {

        fontSiteCheckInterval = setInterval(fontLoadListener, 150, siteFont);
    }catch (e) {
        console.log("init font check: {}", e);
    }
</script>





<script src="/.resources/aa-fe-templating/webresources/dist/app.bundle.js?rndm=76"></script>



    <script src="/.resources/aa-fe-templating/webresources/js/js_cleverTapEvnets.js?rndm=76"></script>

<style>
    .teadsad1, .teadsad2{
       margin: 10px 0;
    }
</style>


<script>
    let articleWraprer = document.querySelector('article #body-text');
    if(articleWraprer){
        var teadAdDiv1 = document.createElement('div');
        teadAdDiv1.classList.add('teadsad1');
        var teadAdDiv2 = document.createElement('div');
        teadAdDiv2.classList.add('teadsad2');
        let nodeListOf = articleWraprer.querySelectorAll("p");
        if(nodeListOf.length>0){
            if(nodeListOf.length>1){
                articleWraprer.insertBefore(teadAdDiv1, nodeListOf[1].nextSibling);
            }
            let lastFth=nodeListOf.length>7? 7 : (nodeListOf.length - 1);
            articleWraprer.insertBefore(teadAdDiv2, nodeListOf[lastFth].nextSibling);
        }
    }

    const scrnWidth=window.screen.availWidth;
    let teadTagElem = document.querySelector('.teads-wrapper');
    if(teadTagElem){
        let teadTag=teadTagElem.dataset.mobTag;
        if(scrnWidth>1199){
            teadTag=teadTagElem.dataset.desktopTag;
        }else if (scrnWidth>500){
            teadTag=teadTagElem.dataset.tabletTag;
        }
        var my_awesome_script = document.createElement('script');
        my_awesome_script.setAttribute('src','//a.teads.tv/page/'+teadTag+'/tag');
        my_awesome_script.setAttribute('async','true');
        teadTagElem.parentNode.insertBefore(my_awesome_script, teadTagElem.nextSibling);
    }
</script>

